# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*.local
.env.local

# keep .env.example tracked
!.env.example

# vercel — never commit CLI state or link config
.vercel

# claude code
.claude/

# audio files
*.m4a

# video project files
/videos/

# resources — PDFs, books, images (too large for git)
/resources/

# supabase CLI temp files
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts
